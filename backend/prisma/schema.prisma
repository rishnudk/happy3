generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  password     String
  name         String?
  emailId      String?  @unique
  phoneNumber  String?
  refreshToken String?
  role         String   @default("admin")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Question {
  id            Int       @id @default(autoincrement())
  questionNo    Int
  category      String
  questionText  String
  isDeleted     Boolean   @default(false)

  options       Option[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Option {
  id          Int      @id @default(autoincrement())
  optionText  String
  mark        Int

  questionId  Int

  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
}

model AssessmentSubmission {
  id          Int      @id @default(autoincrement())
  name        String
  emailId     String
  phoneNumber String
  totalScore  Int
  answers     Json

  createdAt   DateTime @default(now())
}

