generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  password     String
  name         String?
  emailId      String?  @unique
  phoneNumber  String?
  refreshToken String?
  role         Role     @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assessmentSubmissions AssessmentSubmission[]
}

model Question {
  id            Int       @id @default(autoincrement())
  questionNo    Int       @unique
  category      String
  questionText  String
  isDeleted     Boolean   @default(false)

  options       Option[]
  answers       Answer[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Option {
  id          Int      @id @default(autoincrement())
  optionText  String
  mark        Int

  questionId  Int
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  answers     Answer[]

  createdAt   DateTime @default(now())
}

model AssessmentSubmission {
  id          Int      @id @default(autoincrement())
  name        String
  emailId     String
  phoneNumber String
  totalScore  Int
  
  userId      Int?
  user        User?    @relation(fields: [userId], references: [id])

  answers     Answer[]

  createdAt   DateTime @default(now())
}

model Answer {
  id                     Int                  @id @default(autoincrement())
  mark                   Int

  assessmentSubmissionId Int
  assessmentSubmission   AssessmentSubmission @relation(fields: [assessmentSubmissionId], references: [id], onDelete: Cascade)

  questionId             Int
  question               Question             @relation(fields: [questionId], references: [id], onDelete: Cascade)

  optionId               Int
  option                 Option               @relation(fields: [optionId], references: [id], onDelete: Cascade)

  createdAt              DateTime             @default(now())
}

model Challenge {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())

  leads Lead[]
}

model Goal {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())

  leads Lead[]
}

model Program {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())

  leads Lead[]
}

model CallbackTime {
  id        Int      @id @default(autoincrement())
  label     String   @unique
  createdAt DateTime @default(now())

  leads Lead[]
}

enum LeadStatus {
  NEW
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Lead {
  id Int @id @default(autoincrement())

  phone String? @unique
  sessionId String @unique

  name String?

  challengeId Int?
  challenge Challenge? @relation(fields: [challengeId], references: [id])

  goalId Int?
  goal Goal? @relation(fields: [goalId], references: [id])

  programId Int?
  program Program? @relation(fields: [programId], references: [id])

  callbackTimeId Int?
  callbackTime CallbackTime? @relation(fields: [callbackTimeId], references: [id])

  currentStep Int @default(1)

  status LeadStatus @default(NEW)

 createdAt DateTime @default(now())
updatedAt DateTime @default(now()) @updatedAt
}

